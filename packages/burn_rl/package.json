{
  "name": "burn_rl",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "wasm": "wasm-pack build --target web --out-dir pkg --release",
    "wasm:dev": "wasm-pack build --target web --out-dir pkg --dev",
    "dev": "npm run wasm && vite --config config.vite.ts",
    "build": "npm run wasm && tsc && vite build --config config.vite.ts",
    "preview": "vite preview --config config.vite.ts"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-top-level-await": "^1.5.0",
    "vite-plugin-wasm": "^3.4.1"
  }
}
